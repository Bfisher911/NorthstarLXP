# Copy to .env.local and fill in the values below.

# Flip to "true" once you've pasted the service_role key and applied the
# db/schema.sql + db/policies.sql migrations to your Supabase project.
USE_SUPABASE=false

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional
RESEND_API_KEY=
MAIL_FROM=Northstar LXP <no-reply@northstar.app>
